        // PDF Processing
        async function processPDF(f) {
            const b64 = await toBase64(f);
            const r = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${GEMINI_MODEL}:generateContent?key=${GEMINI_KEY}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    contents: [{
                        parts: [
                            { text: 'Você é um especialista em extrair dados de extratos bancários brasileiros. Analise este PDF de extrato bancário e extraia TODAS as transações financeiras. Para cada transação encontrada, retorne: date (formato YYYY-MM-DD), description (descrição completa da transação), value (valor numérico: positivo para créditos/entradas, negativo para débitos/saídas). IMPORTANTE: Extraia absolutamente TODAS as linhas que representam movimentações financeiras. Retorne APENAS o JSON no formato: {"transactions": [{"date": "2025-01-15", "description": "PIX RECEBIDO", "value": 500.00}, {"date": "2025-01-16", "description": "TARIFA BANCARIA", "value": -25.50}]}' },
                            { inline_data: { mime_type: 'application/pdf', data: b64 } }
                        ]
                    }],
                    generationConfig: {
                        temperature: 0.1,
                        maxOutputTokens: 65536,
                        thinkingConfig: { thinkingBudget: 0 }
                    }
                })
            });
            
            if (!r.ok) {
                const e = await r.json();
                throw new Error(e.error?.message || 'Erro na API do Gemini');
            }
            
            const d = await r.json();
            let t = d.candidates?.[0]?.content?.parts?.[0]?.text || '';
            t = t.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();
            
            let p;
            try { p = JSON.parse(t); } catch { p = { transactions: [] }; }
            if (!p.transactions) return [];
            
            return p.transactions.map(x => ({
                id: crypto.randomUUID(),
                data: x.date || '',
                descricao: x.description || '',
                valor: parseFloat(x.value) || 0,
                empresa: '',
                cnpj: '',
                categoria: 'Não categorizado',
                contaDebito: '',
                contaCredito: '',
                historico: '',
                incomum: false
            }));
        }
        
        function toBase64(f) {
            return new Promise((res, rej) => {
                const r = new FileReader();
                r.readAsDataURL(f);
                r.onload = () => res(r.result.split(',')[1]);
                r.onerror = rej;
            });
        }
        
        // OFX Parser
        function parseOFX(t) {
            const entries = [];
            const re = /<STMTTRN>([\s\S]*?)<\/STMTTRN>/gi;
            let m;
            while ((m = re.exec(t)) !== null) {
                const b = m[1];
                const dt = (b.match(/<DTPOSTED>([^<\n]+)/) || [])[1] || '';
                const val = parseFloat((b.match(/<TRNAMT>([^<\n]+)/) || [])[1]) || 0;
                const memo = (b.match(/<MEMO>([^<\n]+)/) || [])[1] || '';
                entries.push({
                    id: crypto.randomUUID(),
                    data: `${dt.slice(0,4)}-${dt.slice(4,6)}-${dt.slice(6,8)}`,
                    descricao: memo,
                    valor: val,
                    empresa: '',
                    cnpj: '',
                    categoria: 'Não categorizado',
                    contaDebito: '',
                    contaCredito: '',
                    historico: '',
                    incomum: false
                });
            }
            return entries;
        }
        
        // CSV Parser
        function parseCSV(t) {
            const lines = t.trim().split('\n');
            const entries = [];
            for (let i = 1; i < lines.length; i++) {
                const cols = lines[i].split(/[;,\t]/);
                if (cols.length >= 3) {
                    let dt = cols[0].trim();
                    if (dt.includes('/')) {
                        const p = dt.split('/');
                        if (p.length === 3) dt = `${p[2]}-${p[1].padStart(2,'0')}-${p[0].padStart(2,'0')}`;
                    }
                    entries.push({
                        id: crypto.randomUUID(),
                        data: dt,
                        descricao: cols[1].trim(),
                        valor: parseFloat(cols[2].replace(/[^\d,.-]/g, '').replace(',', '.')) || 0,
                        empresa: '',
                        cnpj: '',
                        categoria: 'Não categorizado',
                        contaDebito: '',
                        contaCredito: '',
                        historico: '',
                        incomum: false
                    });
                }
            }
            return entries;
        }
        
        // Apply Mapping
        function applyMapping(e) {
            const d = (e.descricao || '').toUpperCase();
            for (const m of state.mappings) {
                if (d.includes(m.k.toUpperCase())) {
                    if (e.valor < 0) {
                        e.contaDebito = e.contaDebito || m.d;
                        e.contaCredito = e.contaCredito || '111';
                    } else {
                        e.contaDebito = e.contaDebito || '111';
                        e.contaCredito = e.contaCredito || m.c;
                    }
                    e.categoria = e.categoria === 'Não categorizado' ? m.cat : e.categoria;
                    e.historico = e.historico || d.slice(0, 50);
                    break;
                }
            }
            return e;
        }
        
        // Detect Unusual Transactions
        function detectUnusual(entries) {
            // Calculate average for debits
            const debitos = entries.filter(e => e.valor < 0);
            if (debitos.length < 3) return entries;
            
            const values = debitos.map(e => Math.abs(e.valor));
            const avg = values.reduce((a, b) => a + b, 0) / values.length;
            const threshold = avg * 3; // 3x average is unusual
            
            return entries.map(e => {
                if (e.valor < 0 && Math.abs(e.valor) > threshold) {
                    e.incomum = true;
                }
                // Also flag uncategorized large transactions
                if (e.categoria === 'Não categorizado' && Math.abs(e.valor) > 5000) {
                    e.incomum = true;
                }
                return e;
            });
        }
        
