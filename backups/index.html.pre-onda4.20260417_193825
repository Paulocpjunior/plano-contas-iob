        // Processar importação de plano (a partir da aba Plano de Contas)
        // Suporta formatos: PDF, TXT e CSV
        function processarImportPlano(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const cnpj = window.cnpjParaImportar;
            if (!cnpj) {
                showToast('CNPJ não definido!', 'error');
                event.target.value = '';
                return;
