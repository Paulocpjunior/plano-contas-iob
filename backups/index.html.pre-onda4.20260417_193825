            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: #fff;
        }
        .success-message h4 {
            font-size: 20px;
            color: #166534;
            margin-bottom: 8px;
        }
        .success-message p {
            color: #15803d;
            margin-bottom: 20px;
        }
        .success-stats {
