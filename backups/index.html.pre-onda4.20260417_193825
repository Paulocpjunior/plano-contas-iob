        // Processar plano de contas em formato PDF
        async function processarPlanoPDF(file, nomePlano, cnpj, event) {
            try {
                showToast('📄 Processando PDF...', 'success');
                
                const arrayBuffer = await file.arrayBuffer();
                const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                
                let textoCompleto = '';
                
                for (let i = 1; i <= pdf.numPages; i++) {
                    const page = await pdf.getPage(i);
                    const textContent = await page.getTextContent();
                    
                    // Preservar estrutura das linhas
                    let lastY = null;
                    let lineText = '';
                    
                    textContent.items.forEach(item => {
                        if (lastY !== null && Math.abs(item.transform[5] - lastY) > 5) {
                            textoCompleto += lineText.trim() + '\n';
                            lineText = '';
                        }
                        lineText += item.str + ' ';
                        lastY = item.transform[5];
                    });
                    
                    if (lineText.trim()) {
                        textoCompleto += lineText.trim() + '\n';
                    }
                }
                
                console.log('PDF páginas:', pdf.numPages);
                console.log('PDF texto extraído:', textoCompleto.length, 'chars');
                
                // Se não extraiu texto, usar OCR
                if (textoCompleto.trim().length < 50) {
                    showToast('🔍 Usando OCR para ler PDF...', 'success');
                    textoCompleto = await extrairTextoPDFComOCR(pdf);
                    console.log('OCR texto extraído:', textoCompleto.length, 'chars');
                }
                
                // Tentar parsear como TXT primeiro
                let contasImportadas = parsearPlanoTXT(textoCompleto);
                console.log('Parser TXT encontrou:', contasImportadas.length);
                
                // Se não encontrar, tentar como CSV
                if (contasImportadas.length === 0) {
                    contasImportadas = parsearPlanoCSV(textoCompleto);
                    console.log('Parser CSV encontrou:', contasImportadas.length);
                }
                
                // Se ainda não encontrar, tentar padrão genérico
                if (contasImportadas.length === 0) {
                    contasImportadas = parsearPlanoGenerico(textoCompleto);
                }
                
                finalizarImportacaoPlano(contasImportadas, nomePlano, cnpj, event);
                
            } catch (err) {
                console.error('Erro ao importar PDF:', err);
                showToast('Erro ao importar PDF: ' + err.message, 'error');
                event.target.value = '';
                window.cnpjParaImportar = null;
            }
        }
        
        // Extrair texto do PDF usando OCR (Tesseract.js)
        async function extrairTextoPDFComOCR(pdf) {
            let textoCompleto = '';
            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            
            // Processar até 10 páginas para não demorar muito
            const maxPages = Math.min(pdf.numPages, 10);
            
            for (let i = 1; i <= maxPages; i++) {
                showToast(`🔍 OCR página ${i}/${maxPages}...`, 'success');
                
                const page = await pdf.getPage(i);
                const viewport = page.getViewport({ scale: 2.0 }); // Escala maior para melhor OCR
                
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                
                await page.render({ canvasContext: ctx, viewport: viewport }).promise;
                
                // Usar Tesseract para OCR
                const result = await Tesseract.recognize(canvas, 'por', {
                    logger: m => console.log('OCR:', m.status, m.progress)
                });
                
                textoCompleto += result.data.text + '\n';
            }
            
            return textoCompleto;
        }
        
        // Parsear conteúdo TXT (formato IOB/SAGE)
        function parsearPlanoTXT(content) {
            const lines = content.split(/\r?\n/).filter(l => l.trim());
            const contasImportadas = [];
            
            lines.forEach(line => {
                const codigo = line.substring(0, 14).trim();
                const descricao = line.substring(40, 77).trim() || line.substring(14, 54).trim();
                const reduzido = line.substring(77).trim() || line.substring(54).trim();
                
                if (codigo && codigo.match(/^\d/)) {
                    let reduzidoNumero = reduzido;
                    if (reduzido.startsWith('5G')) {
                        const match = reduzido.match(/(\d+)$/);
                        if (match) reduzidoNumero = match[1];
                    }
                    
                    contasImportadas.push({
                        codigo: codigo,
                        descricao: descricao,
                        reduzido: reduzidoNumero
                    });
                }
            });
            
            return contasImportadas;
        }
        
        // Parsear conteúdo CSV
        function parsearPlanoCSV(content) {
            const lines = content.split(/\r?\n/).filter(l => l.trim());
            const contasImportadas = [];
            
            // Detectar separador (vírgula, ponto-vírgula ou tab)
            const primeiraLinha = lines[0] || '';
            let separador = ',';
            if (primeiraLinha.includes(';')) separador = ';';
            else if (primeiraLinha.includes('\t')) separador = '\t';
            
            // Pular cabeçalho se existir
            let inicio = 0;
            if (lines[0] && (lines[0].toLowerCase().includes('codigo') || 
                           lines[0].toLowerCase().includes('conta') ||
                           lines[0].toLowerCase().includes('descri'))) {
                inicio = 1;
            }
            
            for (let i = inicio; i < lines.length; i++) {
                const cols = lines[i].split(separador).map(c => c.trim().replace(/^["']|["']$/g, ''));
                
                if (cols.length >= 2) {
                    const codigo = cols[0];
                    const descricao = cols[1];
                    const reduzido = cols[2] || '';
                    
                    if (codigo && codigo.match(/^\d/)) {
                        contasImportadas.push({
                            codigo: codigo,
                            descricao: descricao,
                            reduzido: reduzido
                        });
                    }
                }
            }
            
            return contasImportadas;
        }
        
        // Parsear formato genérico (para PDFs com layout variado)
        function parsearPlanoGenerico(content) {
            const contasImportadas = [];
            console.log('PDF texto extraído (100 chars):', content.substring(0, 100));
            
            // Padrão 1: "1.0.0.00.0000 DESCRIÇÃO" (formato IOB)
            const regexIOB = /(\d+\.\d+\.\d+\.\d+\.\d+)\s+([A-ZÀ-Ÿ][A-ZÀ-Ÿa-zà-ÿ\s\/\-\.\(\)]+)/g;
            let match;
            
            while ((match = regexIOB.exec(content)) !== null) {
                const codigo = match[1].trim();
                const descricao = match[2].trim();
                if (codigo && descricao && descricao.length > 1) {
                    contasImportadas.push({ codigo, descricao: descricao.substring(0, 60), reduzido: '' });
                }
            }
            
            // Padrão 2: "1.01.01 - Descrição" ou "1.01.01 Descrição"
            if (contasImportadas.length === 0) {
                const regex2 = /(\d+(?:\.\d+){1,4})\s*[-–]?\s*([A-Za-zÀ-ÿ][A-Za-zÀ-ÿ\s\/\-\.\(\)]+)/g;
                while ((match = regex2.exec(content)) !== null) {
                    const codigo = match[1].trim();
                    const descricao = match[2].trim();
                    if (codigo && descricao && descricao.length > 2) {
                        contasImportadas.push({ codigo, descricao: descricao.substring(0, 60), reduzido: '' });
                    }
                }
            }
            
            // Padrão 3: Linhas separadas por quebra - "CODIGO DESCRICAO"
            if (contasImportadas.length === 0) {
                const lines = content.split(/[\n\r]+/);
                lines.forEach(line => {
                    const parts = line.trim().split(/\s{2,}/);
                    if (parts.length >= 2) {
                        const codigo = parts[0].trim();
                        const descricao = parts[1].trim();
                        if (codigo.match(/^\d+[\.\d]*/) && descricao.length > 1) {
                            contasImportadas.push({ codigo, descricao: descricao.substring(0, 60), reduzido: '' });
                        }
                    }
                });
            }
            
            // Remover duplicatas
            const unicos = [];
            const vistos = new Set();
            contasImportadas.forEach(c => {
                if (!vistos.has(c.codigo)) {
                    vistos.add(c.codigo);
                    unicos.push(c);
                }
            });
            
            console.log('Contas encontradas (genérico):', unicos.length);
            return unicos;
        }
        
