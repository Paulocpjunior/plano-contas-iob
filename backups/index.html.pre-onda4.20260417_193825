                    console.warn('[API] Falha ao carregar da API, usando localStorage:', err);
                });
            }
        }
        
        // Salvar planos cadastrados
        function savePlanosCadastrados() {
            localStorage.setItem('planosCadastrados_sp', JSON.stringify(planosCadastrados));
        }
        
        // Verificar se CNPJ tem plano cadastrado
        function verificarPlanoPorCNPJ(cnpj) {
            const cnpjLimpo = cnpj.replace(/\D/g, '');
            for (const [nome, plano] of Object.entries(planosCadastrados)) {
                if (plano.cnpj === cnpjLimpo) {
                    return { nome, plano };
                }
            }
            return null;
        }
        
        // Cadastrar plano com TRAVA de CNPJ
        function cadastrarPlanoComCNPJ(nomePlano, cnpj, contas) {
            const cnpjLimpo = cnpj.replace(/\D/g, '');
            planosCadastrados[nomePlano.toUpperCase()] = {
                cnpj: cnpjLimpo,
                contas: contas,
                dataCadastro: new Date().toLocaleDateString('pt-BR')
            };
            savePlanosCadastrados();
        }
        
        // Abrir diálogo de cadastro de plano
        function abrirCadastroPlano() {
            const cnpjAtual = document.getElementById('infoCNPJ').value.replace(/\D/g, '');
            
            if (cnpjAtual.length !== 14) {
                showToast('Primeiro preencha o CNPJ da empresa!', 'error');
                return;
            }
            
            // Verificar se já existe plano para este CNPJ
            const planoExistente = verificarPlanoPorCNPJ(cnpjAtual);
            if (planoExistente) {
                if (!confirm('⚠️ Já existe o plano "' + planoExistente.nome + '" cadastrado para este CNPJ.\n\nDeseja substituir?')) {
                    return;
                }
            }
            
            document.getElementById('planoFileInput').click();
        }
        
        // Importar plano TXT
        function importarPlanoTXT(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const cnpjAtual = document.getElementById('infoCNPJ').value.replace(/\D/g, '');
            const empresaAtual = document.getElementById('infoEmpresa').value || 'EMPRESA';
            
            const nomePlano = prompt('📋 Nome do Plano de Contas:\n(Ex: ' + empresaAtual.substring(0, 20) + ')') || empresaAtual;
            
            if (!nomePlano.trim()) {
                showToast('Nome do plano é obrigatório!', 'error');
                event.target.value = '';
                return;
            }
            
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const content = e.target.result;
                    const lines = content.split(/\r?\n/).filter(l => l.trim());
                    
                    const contasImportadas = [];
                    
                    lines.forEach(line => {
                        const codigo = line.substring(0, 14).trim();
                        const descricao = line.substring(40, 77).trim() || line.substring(14, 54).trim();
                        const reduzido = line.substring(77).trim() || line.substring(54).trim();
                        
                        if (codigo && codigo.match(/^\d/)) {
                            let reduzidoNumero = reduzido;
                            if (reduzido.startsWith('5G')) {
                                const match = reduzido.match(/(\d+)$/);
                                if (match) reduzidoNumero = match[1];
                            }
                            
                            contasImportadas.push({
                                codigo: codigo,
                                descricao: descricao,
                                reduzido: reduzidoNumero
                            });
                        }
                    });
                    
                    if (contasImportadas.length === 0) {
                        throw new Error('Nenhuma conta encontrada no arquivo');
                    }
                    
                    // Remover plano antigo do mesmo CNPJ se existir
                    for (const [nome, plano] of Object.entries(planosCadastrados)) {
                        if (plano.cnpj === cnpjAtual) {
                            delete planosCadastrados[nome];
                            break;
                        }
                    }
                    
                    // Cadastrar novo plano com TRAVA
                    cadastrarPlanoComCNPJ(nomePlano.trim(), cnpjAtual, contasImportadas);
                    
                    const cnpjFormatado = cnpjAtual.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, '$1.$2.$3/$4-$5');
                    
                    showToast('✅ Plano cadastrado com sucesso!', 'success');
                    alert('🔒 PLANO CADASTRADO COM TRAVA\n\n' +
                          'Plano: ' + nomePlano.toUpperCase() + '\n' +
                          'CNPJ: ' + cnpjFormatado + '\n' +
                          'Contas: ' + contasImportadas.length + '\n\n' +
                          '⚠️ Este plano só pode ser usado com este CNPJ!');
                    
                } catch (err) {
                    console.error('Erro ao importar plano:', err);
                    showToast('Erro ao importar: ' + err.message, 'error');
                }
                
                event.target.value = '';
            };
            
            reader.readAsText(file, 'ISO-8859-1');
        }
        
