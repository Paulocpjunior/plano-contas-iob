        .success-stat .num {
            font-size: 32px;
            font-weight: 800;
            color: var(--success);
        }
        .success-stat .label {
            font-size: 12px;
            color: #166534;
            text-transform: uppercase;
        }
        
        /* Form Card */
        .form-card {
            background: #fff;
            border-radius: var(--radius-lg);
            padding: 40px;
            box-shadow: var(--shadow-lg);
            max-width: 900px;
            margin: 0 auto;
            border: 1px solid var(--border-light);
        }
        .form-card h2 {
            margin-bottom: 8px;
            font-size: 24px;
            font-weight: 800;
        }
        .form-card > p {
            color: var(--text-muted);
            margin-bottom: 32px;
        }
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }
        .form-grid .half {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .field { margin-bottom: 0; }
        .field label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 13px;
            color: var(--text-muted);
        }
        .field input,
        .field select {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-family: inherit;
        }
        .field input:focus,
        .field select:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }
        .input-group { position: relative; }
        .input-group input { padding-right: 48px; }
        .input-icon {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 18px;
        }
        .input-icon.success { color: var(--success); }
        .input-icon.loading { animation: spin 1s linear infinite; }
        
        /* Plano de Contas */
        .plano-table th,
        .plano-table td {
            padding: 12px 16px;
        }
        
        /* Export Preview */
        .export-preview {
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 11px;
            background: var(--primary);
            color: #e2e8f0;
            padding: 20px;
            border-radius: var(--radius);
            max-height: 300px;
            overflow: auto;
            white-space: pre;
        }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            color: var(--text-muted);
        }
        .empty-state .icon {
            font-size: 80px;
            margin-bottom: 20px;
            opacity: 0.4;
        }
        .empty-state h3 {
            font-size: 18px;
            margin-bottom: 8px;
        }
        
        /* Toast */
        .toast {
            position: fixed;
            bottom: 28px;
            right: 28px;
            padding: 18px 28px;
            border-radius: var(--radius-sm);
            color: #fff;
            font-weight: 600;
            z-index: 2000;
            animation: slideIn 0.3s;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .toast-success { background: linear-gradient(135deg, var(--success), #059669); }
        .toast-error { background: linear-gradient(135deg, var(--danger), #dc2626); }
        @keyframes slideIn {
            from { transform: translateX(120%); }
            to { transform: translateX(0); }
        }
        
        /* Version Info */
        .version-info {
            position: fixed;
            bottom: 16px;
            left: 16px;
            background: rgba(15, 23, 42, 0.9);
            color: #fff;
            padding: 10px 18px;
            border-radius: var(--radius-sm);
            font-size: 12px;
            z-index: 100;
        }
        .version-info strong { color: var(--accent-light); }
        
        /* Hidden */
        .hidden { display: none !important; }
        
        /* Responsive */
        @media (max-width: 768px) {
            .form-grid { grid-template-columns: 1fr; }
            .form-grid .half { grid-template-columns: 1fr; }
            .header { flex-direction: column; gap: 12px; padding: 16px; }
            .content { padding: 16px; }
            .upload-zone { padding: 40px 20px; }
            .charts-grid { grid-template-columns: 1fr; }
            .filters-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
