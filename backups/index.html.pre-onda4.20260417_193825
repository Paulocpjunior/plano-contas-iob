        /* Processing Overlay */
        .processing-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 23, 42, 0.8);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
        }
        .processing-overlay.show { display: flex; }
        .processing-card {
            background: #fff;
            padding: 48px 60px;
            border-radius: var(--radius-lg);
            text-align: center;
            max-width: 500px;
