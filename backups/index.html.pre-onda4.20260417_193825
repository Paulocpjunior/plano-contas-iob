        .processing-icon {
            width: 100px;
            height: 100px;
            margin: 0 auto 28px;
            position: relative;
        }
        .processing-spinner {
            width: 100%;
            height: 100%;
            border: 4px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .processing-icon .inner-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 36px;
            animation: bounce 1s ease-in-out infinite;
        }
        @keyframes bounce {
            0%, 100% { transform: translate(-50%, -50%); }
            50% { transform: translate(-50%, -60%); }
        }
        .processing-card h3 {
            font-size: 22px;
            margin-bottom: 8px;
            font-weight: 700;
        }
        .processing-card p {
            color: var(--text-muted);
            margin-bottom: 28px;
        }
        .progress-bar {
            height: 8px;
            background: var(--border);
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 16px;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--success));
            width: 0%;
            transition: width 0.5s;
        }
        .processing-steps {
            text-align: left;
            background: var(--bg);
            padding: 20px;
            border-radius: var(--radius-sm);
        }
        .step {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            font-size: 14px;
            color: var(--text-muted);
        }
        .step.active { color: var(--accent); font-weight: 600; }
        .step.done { color: var(--success); }
        .step .check {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid currentColor;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }
        .step.done .check {
            background: var(--success);
            border-color: var(--success);
            color: #fff;
        }
        
        /* Success Message */
        .success-message {
            display: none;
            background: linear-gradient(135deg, #ecfdf5, #d1fae5);
