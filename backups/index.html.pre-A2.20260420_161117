            const q = document.getElementById('searchPlano').value.toLowerCase();
            const plan = PLANOS[tipo] || [];
            const filtered = plan.filter(p => 
                p.d.toLowerCase().includes(q) || p.c.includes(q) || p.r.includes(q)
            );
            
            let h = '<table class="plano-table"><thead><tr><th>Código</th><th>Reduzido</th><th>Descrição</th><th>Tipo</th></tr></thead><tbody>';
            filtered.forEach(p => {
                const b = p.t === 'R' ? 'badge-green' : p.t === 'D' ? 'badge-yellow' : p.t === 'C' ? 'badge-red' : 'badge-blue';
                h += `<tr><td><strong>${p.c}</strong></td><td>${p.r}</td><td>${p.d}</td><td><span class="badge ${b}">${p.t}</span></td></tr>`;
            });
            h += '</tbody></table>';
            document.getElementById('planoTable').innerHTML = h;
        }
        
        // Mapeamento
        function renderMappings() {
            if (!Array.isArray(state.mappings)) state.mappings = [];
            let h = '<table><thead><tr><th>Palavra-chave</th><th>Reduzida Débito</th><th>Reduzida Crédito</th><th>Categoria</th><th></th></tr></thead><tbody>';
            state.mappings.forEach((m, i) => {
                h += `<tr><td><strong>${m.k}</strong></td><td>${m.d}</td><td>${m.c}</td><td><span class="badge badge-gray">${m.cat || '-'}</span></td><td><button class="btn-sugestao" onclick="removeMapping(${i})">🗑️</button></td></tr>`;
            });
            h += '</tbody></table>';
            document.getElementById('mappingTable').innerHTML = h;
        }
        
        function addMapping() {
            const k = document.getElementById('newKeyword').value.trim().toUpperCase();
            const d = document.getElementById('newContaDebito').value.trim();
            const c = document.getElementById('newContaCredito').value.trim();
            const cat = document.getElementById('newCategoria').value;
            
            if (!k) { showToast('Digite uma palavra-chave!', 'error'); return; }
            const rxRed = /^\d{1,6}$/;
            if (d && !rxRed.test(d)) { showToast('Débito inválido: use só a Reduzida (ex: 11, 581), não 1.1.1.03.0002', 'error'); return; }
            if (c && !rxRed.test(c)) { showToast('Crédito inválido: use só a Reduzida (ex: 11, 581), não 1.1.1.03.0002', 'error'); return; }
            if (!d && !c) { showToast('Informe ao menos a Reduzida de Débito ou Crédito', 'error'); return; }
            state.mappings.push({ k, d, c, cat });
            saveState();
            renderMappings();
            
            document.getElementById('newKeyword').value = '';
            document.getElementById('newContaDebito').value = '';
            document.getElementById('newContaCredito').value = '';
            document.getElementById('newCategoria').value = '';
            
            showToast('Mapeamento adicionado!', 'success');
        }
        
        function removeMapping(i) {
            state.mappings.splice(i, 1);
            saveState();
            renderMappings();
        }
        
        // Export Functions
        function toggleExportDropdown() {
            document.getElementById('exportDropdown').classList.toggle('show');
        }
        
        // Close dropdown when clicking outside
        document.addEventListener('click', e => {
            if (!e.target.closest('.dropdown')) {
                document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('show'));
            }
        });
        
        // Classificar transações com IA usando plano de contas vinculado ao CNPJ
        async function classificarComIA() {
            // Verificar se tem transações
            if (!state.entries || state.entries.length === 0) {
                showToast('Nenhuma transação para classificar!', 'error');
                return;
            }
            
            // Verificar se tem CNPJ preenchido
            const cnpj = state.info?.cnpj?.replace(/\D/g, '');
            if (!cnpj || cnpj.length !== 14) {
                showToast('CNPJ não informado! Volte e preencha os dados da empresa.', 'error');
                return;
            }
            
            // Buscar plano de contas vinculado ao CNPJ
            let planoVinculado = null;
            let nomePlano = null;
            
            for (const [nome, plano] of Object.entries(planosCadastrados)) {
                if (plano.cnpj === cnpj) {
                    planoVinculado = plano;
                    nomePlano = nome;
                    break;
                }
            }
            
            if (!planoVinculado) {
                const cnpjFormatado = cnpj.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, '$1.$2.$3/$4-$5');
                showToast('Nenhum plano de contas cadastrado para o CNPJ ' + cnpjFormatado, 'error');
                alert('⚠️ PLANO DE CONTAS NÃO ENCONTRADO\n\nO CNPJ ' + cnpjFormatado + ' não possui plano de contas cadastrado.\n\nVá em 📚 Plano de Contas → + Importar Novo Plano\ne cadastre o plano para este CNPJ.');
                return;
            }
            
            // Preparar contas para enviar à IA
            const contasPlano = planoVinculado.contas.map(c => ({
                codigo: c.codigo,
                descricao: c.descricao,
                reduzido: c.reduzido || ''
            }));
            
            showToast(`🤖 Classificando ${state.entries.length} transações com plano ${nomePlano}...`, 'success');
            
            const btn = document.getElementById('btnClassificarIA');
            btn.disabled = true;
            btn.innerHTML = '⏳ Classificando...';
            
            try {
                // Classificar em lotes de 20
                const batchSize = 20;
                let classificadas = 0;
                
                for (let i = 0; i < state.entries.length; i += batchSize) {
                    const batch = state.entries.slice(i, i + batchSize);
                    
                    const prompt = `Você é um contador especialista. Classifique cada transação bancária usando APENAS as contas do plano de contas fornecido.

PLANO DE CONTAS (use APENAS estas contas):
${contasPlano.slice(0, 200).map(c => `${c.codigo} - ${c.descricao}`).join('\n')}

TRANSAÇÕES PARA CLASSIFICAR:
${batch.map((t, idx) => `${idx + 1}. ${t.data} | ${t.descricao} | R$ ${Math.abs(t.valor).toFixed(2)} | ${t.valor >= 0 ? 'CRÉDITO' : 'DÉBITO'}`).join('\n')}

Responda APENAS com JSON válido, sem texto adicional:
{
  "classificacoes": [
    {"idx": 1, "contaDebito": "CÓDIGO", "contaCredito": "CÓDIGO", "historico": "CÓDIGO_HISTORICO"},
    ...
  ]
}

REGRAS:
- Use APENAS códigos de contas que existem no plano acima
- Para CRÉDITOS (entradas): Débito em conta de Ativo (1.x), Crédito em conta de Receita (4.x)
- Para DÉBITOS (saídas): Débito em conta de Despesa (3.x ou 4.x), Crédito em conta de Ativo (1.x)
- historico: código numérico de 1-4 dígitos (ex: "1001")`;

                    const response = await window.API.callGemini({
                            contents: [{ parts: [{ text: prompt }] }],
                            generationConfig: {
                                temperature: 0.1,
                                maxOutputTokens: 8192,
                                thinkingConfig: { thinkingBudget: 0 }
                            }
                        });
                    
                    const data = await response.json();
                    const text = data.candidates?.[0]?.content?.parts?.[0]?.text || '';
                    
                    // Extrair JSON da resposta
                    const jsonMatch = text.match(/\{[\s\S]*\}/);
                    if (jsonMatch) {
                        const result = JSON.parse(jsonMatch[0]);
                        
                        if (result.classificacoes) {
                            result.classificacoes.forEach(c => {
                                const entryIdx = i + c.idx - 1;
                                if (state.entries[entryIdx]) {
                                    state.entries[entryIdx].contaDebito = c.contaDebito || '';
                                    state.entries[entryIdx].contaCredito = c.contaCredito || '';
                                    state.entries[entryIdx].historico = c.historico || '1';
                                    classificadas++;
                                }
                            });
                        }
                    }
                    
                    btn.innerHTML = `⏳ ${Math.min(i + batchSize, state.entries.length)}/${state.entries.length}...`;
                }
                
                saveState();
                renderLancamentos();
                
                showToast(`✅ ${classificadas} transações classificadas com sucesso!`, 'success');
                
            } catch (err) {
                console.error('Erro ao classificar:', err);
                showToast('Erro ao classificar: ' + err.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '🤖 Classificar com IA';
            }
        }
        
        function exportIOB() {
            const cc = (document.getElementById('cfgCentroCusto').value || '00000').padEnd(5).slice(0, 5);
            const tipo = (document.getElementById('cfgTipo').value || 'DIARIO').padEnd(8).slice(0, 8);
            const valid = state.entries.filter(e => e.contaDebito && e.contaCredito);
            
            if (!valid.length) {
                showToast('Nenhum lançamento classificado para exportar!', 'error');
                return;
            }
            
            const lines = valid.map(e => {
                const deb = (e.contaDebito || '').padEnd(18).slice(0, 18);
                const cred = (e.contaCredito || '').padEnd(18).slice(0, 18);
                const val = Math.abs(Math.round(e.valor * 100)).toString().padStart(12, '0');
                let dt = e.data || '';
                if (dt.includes('-')) {
                    const p = dt.split('-');
                    dt = `${p[2]}/${p[1]}/${p[0]}`;
                }
                dt = dt.padEnd(10).slice(0, 10);
                const hist = (e.historico || e.descricao || '').toUpperCase().slice(0, 120).padEnd(120);
                return deb + cred + cc + val + dt + hist + 'IMP_FINANCEIRO'.padEnd(20) + tipo + 'N';
            });
            
            document.getElementById('exportPreview').textContent = lines.join('\n');
            document.getElementById('exportStats').classList.remove('hidden');
            document.getElementById('exportInfo').innerHTML = `<strong>${valid.length}</strong> lançamentos exportados | ${state.entries.length - valid.length} pendentes`;
            
            const blob = new Blob([lines.join('\r\n')], { type: 'text/plain' });
            const a = document.createElement('a');
            const emp = (state.info?.empresa || 'empresa').replace(/[^a-zA-Z0-9]/g, '_').slice(0, 20);
            a.href = URL.createObjectURL(blob);
            a.download = `${emp}_${new Date().toISOString().slice(0, 10)}.02`;
            a.click();
            
            showToast('Arquivo IOB gerado com sucesso!', 'success');
        }
        
        function exportCSV() {
            const valid = state.entries.filter(e => e.contaDebito && e.contaCredito);
            if (!valid.length) {
                showToast('Nenhum lançamento para exportar!', 'error');
