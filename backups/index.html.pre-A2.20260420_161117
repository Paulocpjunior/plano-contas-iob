        function empFmtDate(ts) {
            if (!ts) return '—';
            const d = ts._seconds ? new Date(ts._seconds * 1000) : (ts.seconds ? new Date(ts.seconds * 1000) : new Date(ts));
            if (isNaN(d.getTime())) return '—';
            const diff = Date.now() - d.getTime();
            const m = Math.floor(diff / 60000);
            if (m < 1) return 'agora';
            if (m < 60) return 'há ' + m + ' min';
            const h = Math.floor(m / 60);
            if (h < 24) return 'há ' + h + 'h';
            const dias = Math.floor(h / 24);
            if (dias < 30) return 'há ' + dias + 'd';
            return d.toLocaleDateString('pt-BR');
        }

        function empFmtCNPJ(c) {
            const x = (c || '').replace(/\D/g, '');
            if (x.length !== 14) return c;
            return x.slice(0,2) + '.' + x.slice(2,5) + '.' + x.slice(5,8) + '/' + x.slice(8,12) + '-' + x.slice(12);
