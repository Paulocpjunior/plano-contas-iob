        function importarPlanoTXT(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const cnpjAtual = document.getElementById('infoCNPJ').value.replace(/\D/g, '');
            const empresaAtual = document.getElementById('infoEmpresa').value || 'EMPRESA';
            
