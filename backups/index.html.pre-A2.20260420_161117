            const despesas = state.entries.filter(e => e.valor < 0);
            const catData = {};
            despesas.forEach(e => {
                const cat = e.categoria || 'Não categorizado';
                catData[cat] = (catData[cat] || 0) + Math.abs(e.valor);
            });
            
            const sortedCats = Object.entries(catData).sort((a, b) => b[1] - a[1]).slice(0, 8);
            chartCategorias.data.labels = sortedCats.map(([k]) => k);
            chartCategorias.data.datasets[0].data = sortedCats.map(([, v]) => v);
            chartCategorias.update();
            try { atualizarResumoCategoria(); } catch(e) { console.warn('[resumoCat]', e); }
            
            // Update Fluxo (by month)
            const monthData = {};
            state.entries.forEach(e => {
                if (!e.data) return;
                const [year, month] = e.data.split('-');
                const key = `${month}/${year.slice(2)}`;
                if (!monthData[key]) monthData[key] = { entradas: 0, saidas: 0 };
                if (e.valor > 0) monthData[key].entradas += e.valor;
                else monthData[key].saidas += Math.abs(e.valor);
            });
            
            const months = Object.keys(monthData).sort();
            chartFluxo.data.labels = months;
            chartFluxo.data.datasets[0].data = months.map(m => monthData[m].entradas);
            chartFluxo.data.datasets[1].data = months.map(m => monthData[m].saidas);
            chartFluxo.update();
