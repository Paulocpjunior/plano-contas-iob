            t.classList.remove('hidden');
            setTimeout(() => t.classList.add('hidden'), 4000);
        }
        
        // Console log
        console.log('%cCONSULTOR CONTÁBIL v2.2.0', 'color:#3b82f6;font-weight:bold;font-size:16px');
