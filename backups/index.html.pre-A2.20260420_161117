                    inpEmpresa.disabled = false;
                    showToast('❌ CNPJ nao encontrado na Receita Federal', 'error');
                    window.__cnpjValidado = false;
                    return;
                }
            } catch (e) {
                console.warn('[BrasilAPI] erro de rede:', e);
                // Em caso de timeout/rede, libera edicao manual mas sinaliza
                inpEmpresa.value = '';
                inpEmpresa.disabled = false;
                icon.innerHTML = '⚠';
                icon.className = 'input-icon';
                showToast('⚠️ Nao foi possivel consultar a Receita Federal. Preencha manualmente.', 'warn');
                window.__cnpjValidado = 'offline';
