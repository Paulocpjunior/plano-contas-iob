async function abrirVincularPlanoModalComGenericos() {
  // Variacao que agrupa planos genericos (sem CNPJ) no topo
  const cnpjAtual = (document.getElementById('infoCNPJ') || {}).value || '';
  const razaoAtual = (document.getElementById('infoEmpresa') || {}).value || '';
  document.getElementById('vinpCNPJ').value = cnpjAtual;
  document.getElementById('vinpRazao').value = razaoAtual;
  document.getElementById('vinpMsg').innerHTML = '<span style="color:#059669">✨ Escolha um plano generico (sem empresa especifica) ou vincule um existente.</span>';
  const sel = document.getElementById('vinpPlano');
  sel.innerHTML = '<option value="">Carregando...</option>';
  document.getElementById('vincularPlanoModal').style.display = 'flex';
  try {
    const planos = await window.API.loadPlanos();
    let entries = [];
    if (Array.isArray(planos)) {
      entries = planos.map(p => [p.nome || p.name || p.plano_id, p]);
    } else if (planos && typeof planos === 'object') {
      entries = Object.entries(planos);
    }
    if (!entries.length) { sel.innerHTML = '<option value="">Nenhum plano disponivel</option>'; return; }
    entries.sort((a, b) => a[0].localeCompare(b[0]));

    const genericos = [];
    const especificos = [];
    entries.forEach(([nome, p]) => {
      const id = p.plano_id || p.id || p._id;
      if (!id) return;
      const temCNPJ = p.cnpj && String(p.cnpj).replace(/\D/g,'').length === 14;
      if (temCNPJ) especificos.push([nome, p, id]); else genericos.push([nome, p, id]);
    });

    sel.innerHTML = '<option value="">-- Selecione um plano --</option>';
    if (genericos.length) {
      const gGroup = document.createElement('optgroup');
      gGroup.label = '📚 PLANOS GENERICOS (recomendados)';
      genericos.forEach(([nome, p, id]) => {
        const opt = document.createElement('option');
        opt.value = id;
        opt.textContent = nome;
        gGroup.appendChild(opt);
      });
      sel.appendChild(gGroup);
    }
    if (especificos.length) {
      const eGroup = document.createElement('optgroup');
      eGroup.label = '🏢 PLANOS DE OUTRAS EMPRESAS';
      especificos.forEach(([nome, p, id]) => {
        const cnpjFmt = String(p.cnpj).replace(/\D/g,'').replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, '$1.$2.$3/$4-$5');
        const opt = document.createElement('option');
        opt.value = id;
        opt.textContent = nome + ' (' + cnpjFmt + ')';
        eGroup.appendChild(opt);
      });
      sel.appendChild(eGroup);
    }
  } catch (e) {
    sel.innerHTML = '<option value="">Erro ao carregar</option>';
    document.getElementById('vinpMsg').textContent = 'Erro: ' + e.message;
  }
}

