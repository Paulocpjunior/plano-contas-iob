        // Migrador de shape de lancamentos (corrige date->data, description->descricao, value->valor)
        function migrarShapeLancamentos() {
            if (!state.entries || !Array.isArray(state.entries)) return 0;
            let migrados = 0;
            state.entries = state.entries.map(e => {
                if (!e) return e;
                // Se ja tem shape correto, mantem
                if (typeof e.valor === 'number' && e.data && e.descricao) return e;
                // Shape ingles -> portugues
                const novo = {
                    id: e.id || crypto.randomUUID(),
                    data: e.data || e.date || '',
                    descricao: e.descricao || e.description || '',
                    valor: typeof e.valor === 'number' ? e.valor : (typeof e.value === 'number' ? e.value : parseFloat(e.valor || e.value || 0) || 0),
                    empresa: e.empresa || '',
                    cnpj: e.cnpj || '',
                    categoria: e.categoria || 'Nao categorizado',
                    contaDebito: e.contaDebito || '',
                    contaCredito: e.contaCredito || '',
                    historico: e.historico || '',
                    incomum: e.incomum || false,
                    origem: e.origem || 'migrado'
                };
                // Remove se nao tem dados minimos
                if (!novo.data || !novo.valor) { migrados++; return null; }
                migrados++;
                return novo;
            }).filter(Boolean);
            if (migrados > 0) console.log('[migrator] ' + migrados + ' lancamentos migrados/limpos');
            return migrados;
        }

                // Resumo por Categoria (tabela detalhada)
        function atualizarResumoCategoria() {
            const tbody = document.getElementById('tbodyResumoCategoria');
            const tfoot = document.getElementById('tfootResumoCategoria');
            if (!tbody) return;
            const despesas = (state.entries || []).filter(e => typeof e.valor === 'number' && e.valor < 0);
            if (despesas.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" style="padding:20px;text-align:center;color:#9ca3af">Nenhum lançamento de despesa</td></tr>';
                if (tfoot) tfoot.innerHTML = '';
                return;
            }
            // Agrupa por categoria
            const grupos = {};
            despesas.forEach(e => {
                const cat = (e.categoria || 'Não categorizado').trim() || 'Não categorizado';
                if (!grupos[cat]) grupos[cat] = { qtd: 0, total: 0 };
                grupos[cat].qtd++;
                grupos[cat].total += Math.abs(e.valor);
            });
            const totalGeral = Object.values(grupos).reduce((acc, g) => acc + g.total, 0);
            // Ordena do maior pro menor
            const ordenado = Object.entries(grupos).sort((a, b) => b[1].total - a[1].total);
            // Paleta de cores simples por posicao
            const cores = ['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#ec4899','#14b8a6','#f97316','#6366f1','#84cc16'];
            let html = '';
            ordenado.forEach(([cat, g], idx) => {
                const pct = totalGeral > 0 ? (g.total / totalGeral * 100) : 0;
                const cor = cores[idx % cores.length];
                html += '<tr style="border-bottom:1px solid #f3f4f6">'
                    + '<td style="padding:10px 12px">'
                    +   '<span style="display:inline-block;width:10px;height:10px;background:' + cor + ';border-radius:50%;margin-right:8px;vertical-align:middle"></span>'
                    +   '<span style="font-weight:500;color:#111827">' + cat + '</span>'
                    + '</td>'
                    + '<td style="padding:10px 12px;text-align:center;color:#6b7280">' + g.qtd + '</td>'
                    + '<td style="padding:10px 12px;text-align:right;font-family:monospace;color:#dc2626;font-weight:600">R$ ' + g.total.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                    + '<td style="padding:10px 12px;text-align:right">'
                    +   '<div style="display:inline-flex;align-items:center;gap:8px">'
                    +     '<div style="width:60px;height:6px;background:#f3f4f6;border-radius:3px;overflow:hidden"><div style="width:' + pct.toFixed(1) + '%;height:100%;background:' + cor + '"></div></div>'
                    +     '<span style="min-width:45px;color:#374151;font-variant-numeric:tabular-nums">' + pct.toFixed(1) + '%</span>'
                    +   '</div>'
                    + '</td>'
                    + '</tr>';
            });
            tbody.innerHTML = html;
            if (tfoot) {
                tfoot.innerHTML = '<tr style="background:#f9fafb;font-weight:700">'
                    + '<td style="padding:12px;border-top:2px solid #e5e7eb;color:#111827">TOTAL</td>'
                    + '<td style="padding:12px;text-align:center;border-top:2px solid #e5e7eb;color:#111827">' + despesas.length + '</td>'
                    + '<td style="padding:12px;text-align:right;border-top:2px solid #e5e7eb;font-family:monospace;color:#dc2626">R$ ' + totalGeral.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}) + '</td>'
                    + '<td style="padding:12px;text-align:right;border-top:2px solid #e5e7eb;color:#6b7280">100,0%</td>'
                    + '</tr>';
            }
        }

                // Dashboard
        function updateDashboard() {
            if (!state.info) return;
            
            const total = state.entries.length;
            const classificados = state.entries.filter(e => e.contaDebito && e.contaCredito).length;
            const pendentes = total - classificados;
            const creditos = state.entries.filter(e => e.valor > 0).reduce((a, e) => a + e.valor, 0);
            const debitos = state.entries.filter(e => e.valor < 0).reduce((a, e) => a + Math.abs(e.valor), 0);
            const saldo = creditos - debitos;
            const movimentacao = creditos + debitos;
            
            document.getElementById('dashTotal').textContent = total;
            document.getElementById('dashClass').textContent = classificados;
            document.getElementById('dashClassPercent').textContent = total ? Math.round(classificados / total * 100) + '% do total' : '0% do total';
            document.getElementById('dashPend').textContent = pendentes;
            document.getElementById('dashPendPercent').textContent = total ? Math.round(pendentes / total * 100) + '% do total' : '0% do total';
            document.getElementById('dashValor').textContent = 'R$ ' + movimentacao.toLocaleString('pt-BR', {minimumFractionDigits: 2});
            document.getElementById('dashSaldo').textContent = 'Saldo: R$ ' + saldo.toLocaleString('pt-BR', {minimumFractionDigits: 2});
        }
        
