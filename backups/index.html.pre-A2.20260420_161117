        // [A1.3] Validacao matematica do digito verificador do CNPJ
        function validarCNPJDigito(cnpj) {
            cnpj = String(cnpj || '').replace(/\D/g, '');
            if (cnpj.length !== 14) return false;
            if (/^(\d)\1{13}$/.test(cnpj)) return false;  // todos iguais (ex: 11111...)
            const calc = (base) => {
                let soma = 0;
                const pesos = base.length === 12 ? [5,4,3,2,9,8,7,6,5,4,3,2] : [6,5,4,3,2,9,8,7,6,5,4,3,2];
                for (let i = 0; i < base.length; i++) soma += parseInt(base[i]) * pesos[i];
                const resto = soma % 11;
                return resto < 2 ? 0 : 11 - resto;
            };
            const d1 = calc(cnpj.substring(0, 12));
            const d2 = calc(cnpj.substring(0, 13));
            return d1 === parseInt(cnpj[12]) && d2 === parseInt(cnpj[13]);
        }

        async function buscarCNPJ() {
            aplicarUICadastroEmpresa(false, true);
            const cnpj = document.getElementById('infoCNPJ').value.replace(/\D/g, '');
            const icon = document.getElementById('cnpjIcon');
            const inpEmpresa = document.getElementById('infoEmpresa');

            if (cnpj.length !== 14) {
                icon.innerHTML = '';
                icon.className = 'input-icon';
                return;
            }

            // [CAMADA 1] Validacao matematica
            if (!validarCNPJDigito(cnpj)) {
                icon.innerHTML = '✗';
                icon.className = 'input-icon error';
                inpEmpresa.value = '';
                inpEmpresa.disabled = true;
                showToast('❌ CNPJ invalido (digitos verificadores nao batem)', 'error');
                window.__cnpjValidado = false;
                return;
            }

            icon.innerHTML = '⟳';
            icon.className = 'input-icon loading';
            inpEmpresa.disabled = true;
            inpEmpresa.value = '⟳ Consultando Receita Federal...';

            // [CAMADA 2] Consulta BrasilAPI
            let razaoSocial = null;
            try {
                const r = await fetch(`https://brasilapi.com.br/api/cnpj/v1/${cnpj}`);
                if (r.ok) {
                    const d = await r.json();
                    razaoSocial = d.razao_social || d.nome_fantasia || null;
