        // State Management
        function loadState() {
            const s = localStorage.getItem('consultorContabil_v2');
            if (s) {
                const d = JSON.parse(s);
                state.entries = d.entries || [];
                state.mappings = Array.isArray(d.mappings) ? d.mappings : (Array.isArray(state.mappings) ? state.mappings : []);
                state.info = d.info || null;
                state.infoConfirmed = d.infoConfirmed || false;
                state.lastFile = d.lastFile || null;
            }
            if (!Array.isArray(state.mappings)) state.mappings = [];
        }
        
        function saveState() {
            localStorage.setItem('consultorContabil_v2', JSON.stringify({
                entries: state.entries,
                mappings: state.mappings,
                info: state.info,
                infoConfirmed: state.infoConfirmed,
                lastFile: state.lastFile
            }));
            localStorage.setItem('consultorContabil_v2_ts', String(Date.now()));
            // Auto-save remoto (debounced 3s) so quando tem empresa confirmada
            if (state.infoConfirmed && state.info && state.info.cnpj) {
                try { agendarSaveRemoto(); } catch (e) {}
            }
        }
        
        // Sincroniza sessao local com Firestore (puxa remota se for mais nova)
        async function sincronizarSessaoRemoto() {
            try {
                if (!state.info || !state.info.cnpj) return;
                const cnpj = (state.info.cnpj || '').replace(/\D/g, '');
                if (cnpj.length !== 14) return;
                if (!window.API || !window.API.carregarSessaoEmpresa) return;
                const sess = await window.API.carregarSessaoEmpresa(cnpj);
                if (!sess || !sess.encontrada || !sess.state_json) return;
                const remotoTs = sess.updated_at && sess.updated_at._seconds ? sess.updated_at._seconds * 1000 : 0;
                const localTs = parseInt(localStorage.getItem('consultorContabil_v2_ts') || '0', 10);
                const qtdRemoto = (sess.resumo && sess.resumo.total_lancamentos) || 0;
                const qtdLocal = (state.entries || []).length;
                // Se remoto eh mais novo OU tem mais dados significativos, pergunta
                const remotoMaisNovo = remotoTs > localTs + 5000; // 5s de tolerancia
                const remotoTemMais = qtdRemoto > qtdLocal + 5;
                if (!remotoMaisNovo && !remotoTemMais) return;
                const quando = remotoTs ? new Date(remotoTs).toLocaleString('pt-BR') : 'desconhecido';
                const por = sess.updated_by_email || 'outro usuario';
                const msg = '🔄 Versão mais recente no servidor\n\nLocal: ' + qtdLocal + ' lançamento(s)\nServidor: ' + qtdRemoto + ' lançamento(s)\nÚltimo save: ' + quando + '\nPor: ' + por + '\n\nCarregar versão do servidor?';
                if (confirm(msg)) {
                    const d = JSON.parse(sess.state_json);
                    state.entries = d.entries || [];
                    state.mappings = Array.isArray(d.mappings) ? d.mappings : (Array.isArray(state.mappings) ? state.mappings : []);
                    state.info = d.info || state.info;
                    state.infoConfirmed = d.infoConfirmed || state.infoConfirmed;
                    state.lastFile = d.lastFile || state.lastFile;
                    localStorage.setItem('consultorContabil_v2_ts', String(remotoTs));
                    saveState();
                    showToast('✅ Sessão sincronizada do servidor (' + qtdRemoto + ' lançamentos)', 'success');
                    setTimeout(() => location.reload(), 1500);
                }
            } catch (e) { console.warn('[sessao] sync:', e); }
        }

