        // ============ IMPORTAR NOVO LANCAMENTO (.xls/.xlsx/.csv/.txt/.o2) ============
        async function importarLancamentoArquivo(event) {
            const file = event.target.files[0];
            if (!file) return;
            if (!state.infoConfirmed || !state.info) {
                showToast('Confirme os dados da empresa primeiro', 'error');
                event.target.value = '';
                return;
            }
            showToast('📋 Processando ' + file.name + '...', 'success');
            try {
                const nome = (file.name || '').toLowerCase();
                let lancamentosBrutos = [];
                let formato = 'desconhecido';
                // Auto-detect de sinal pelo nome do arquivo
                const ehRelatorioDespesa = /(credito|despesa|relatorio)/i.test(nome);
                const opts = { forcarNegativo: ehRelatorioDespesa };
                if (nome.endsWith('.o2')) {
                    lancamentosBrutos = await parsearArquivoO2(file);
                    formato = 'O2 (IOB)';
                } else if (nome.endsWith('.xlsx') || nome.endsWith('.xls')) {
                    lancamentosBrutos = await parsearArquivoXLSX(file, opts);
                    formato = nome.endsWith('.xlsx') ? 'XLSX' : 'XLS';
                } else if (nome.endsWith('.csv')) {
                    lancamentosBrutos = await parsearArquivoTexto(file, 'csv', opts);
                    formato = 'CSV';
                } else if (nome.endsWith('.txt')) {
                    lancamentosBrutos = await parsearArquivoTexto(file, 'txt', opts);
                    formato = 'TXT';
                } else {
                    throw new Error('Extensao nao suportada: ' + nome);
                }
                if (ehRelatorioDespesa && lancamentosBrutos.length > 0) {
                    formato += ' (despesa - valores negativos)';
                }
                if (!lancamentosBrutos || lancamentosBrutos.length === 0) {
                    showToast('Nenhum lancamento reconhecido no arquivo', 'error');
                    event.target.value = '';
                    return;
                }
                abrirModalImportarLancamento(lancamentosBrutos, file.name, formato);
            } catch (e) {
                console.error('[importarLancamento]', e);
                showToast('Erro: ' + e.message, 'error');
            } finally {
                event.target.value = '';
            }
        }

        async function parsearArquivoXLSX(file, opts) {
            if (typeof XLSX === 'undefined') throw new Error('SheetJS nao carregada. Recarregue a pagina.');
            let wb;
            try {
                const buf = await file.arrayBuffer();
                wb = XLSX.read(buf, { type: 'array', cellDates: true, raw: false });
            } catch (e) {
                throw new Error('Falha ao ler XLSX: ' + e.message);
            }

            // Normalizador de cabecalho (remove acentos, lowercase, trim)
            const normH = (s) => String(s || '').toLowerCase().trim().replace(/\s+/g,' ')
                .replace(/[áàâãä]/g,'a').replace(/[éèêë]/g,'e').replace(/[íìîï]/g,'i')
                .replace(/[óòôõö]/g,'o').replace(/[úùûü]/g,'u').replace(/[ç]/g,'c');

            const H_DATA  = ['data','data lancamento','data mov','data movimento','dt','data do lancamento'];
            const H_DESC  = ['descricao','historico','lancamento','memo','descricao do lancamento','historico do lancamento'];
            const H_VALOR = ['valor','valor (r$)','montante','vlr','valor lancamento','valor r$','credito/debito'];

            const findCol = (hs, kws) => { const n = hs.map(normH); for (let i=0;i<n.length;i++) if (kws.includes(n[i])) return i; return -1; };

            const detectHeaderRow = (rows) => {
                for (let i=0; i<Math.min(rows.length,25); i++) {
                    const r = (rows[i]||[]).map(normH);
                    const hasD = r.some(c => H_DATA.includes(c));
                    const hasV = r.some(c => H_VALOR.includes(c));
                    const hasX = r.some(c => H_DESC.includes(c));
                    if (hasD && hasV && hasX) return i;
                }
                return -1;
            };

            const parseData = (v) => {
                if (!v && v !== 0) return null;
                if (v instanceof Date) {
                    const y=v.getFullYear(), m=String(v.getMonth()+1).padStart(2,'0'), d=String(v.getDate()).padStart(2,'0');
                    return y+'-'+m+'-'+d;
                }
                if (typeof v === 'number' && XLSX.SSF) {
                    const d = XLSX.SSF.parse_date_code(v);
                    if (d && d.y) return d.y+'-'+String(d.m).padStart(2,'0')+'-'+String(d.d).padStart(2,'0');
                }
                const s = String(v).trim();
                const m = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})$/);
                if (m) { const y = m[3].length===2 ? '20'+m[3] : m[3]; return y+'-'+m[2].padStart(2,'0')+'-'+m[1].padStart(2,'0'); }
                if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
                return null;
            };

            const parseValor = (v) => {
                if (typeof v === 'number') return v;
                if (!v) return null;
                const s = String(v).trim().replace(/R\$\s*/gi,'').replace(/\./g,'').replace(',','.').replace(/\s/g,'');
                const n = parseFloat(s);
                return isNaN(n) ? null : n;
            };

            const todos = [];
            const abasLog = [];

            for (const sheetName of wb.SheetNames) {
                const sheet = wb.Sheets[sheetName];
                const rows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: '', raw: false });
                if (!rows.length) { abasLog.push({aba: sheetName, detectados: 0, motivo: 'vazia'}); continue; }

                const hIdx = detectHeaderRow(rows);
                if (hIdx === -1) { abasLog.push({aba: sheetName, detectados: 0, motivo: 'sem cabecalho reconhecivel'}); continue; }

                const headers = rows[hIdx];
                const cD = findCol(headers, H_DATA);
                const cX = findCol(headers, H_DESC);
                const cV = findCol(headers, H_VALOR);

                let count = 0;
                for (let i = hIdx+1; i < rows.length; i++) {
                    const r = rows[i];
                    if (!r || r.every(c => c===null || c==='' || c===undefined)) continue;
                    const data = parseData(r[cD]);
                    const valor = parseValor(r[cV]);
                    const desc = String(r[cX]||'').trim();
                    if (!data || valor === null || !desc) continue;
                    if (/saldo\s+(anterior|final|do dia|atual|inicial)/i.test(desc)) continue;
                    if (/total\s+(do dia|geral|periodo)/i.test(desc)) continue;

                    todos.push({ data, descricao: desc, valor, aba_origem: sheetName });
                    count++;
                }
                abasLog.push({aba: sheetName, detectados: count});
            }

            // Dedup por data|descricao|valor
            const seen = new Set();
            const deduped = todos.filter(t => {
                const k = t.data+'|'+t.descricao+'|'+t.valor;
                if (seen.has(k)) return false;
                seen.add(k); return true;
            });

            console.log('[parsearArquivoXLSX] abas processadas:', abasLog);
            console.log('[parsearArquivoXLSX] total deduped:', deduped.length);

            // Expor log pro modal de preview
            window.__ultimaImportacaoAbas = abasLog;

            return deduped;
        }


        function detectarColunas(headerRow) {
            const mapa = { data: -1, descricao: -1, valor: -1, descricao_aux: -1, categoria: -1 };
            (headerRow || []).forEach((cell, idx) => {
                const norm = String(cell || '').trim();
                if (!norm) return;
                if (mapa.data < 0 && PADROES_COL.data.test(norm)) { mapa.data = idx; return; }
                if (mapa.valor < 0 && PADROES_COL.valor.test(norm)) { mapa.valor = idx; return; }
                if (mapa.categoria < 0 && PADROES_COL.categoria.test(norm)) { mapa.categoria = idx; return; }
                if (PADROES_COL.descricao.test(norm)) {
                    if (mapa.descricao < 0) mapa.descricao = idx;
                    else if (mapa.descricao_aux < 0) mapa.descricao_aux = idx;
                }
            });
            return mapa;
        }

        // Procura linha de cabecalho por "densidade" de palavras-chave
        function acharLinhaCabecalho(rows) {
            const max = Math.min(15, rows.length);
            let melhor = null; let melhorScore = 0;
            for (let i = 0; i < max; i++) {
                const row = rows[i] || [];
                let score = 0;
                for (const cell of row) {
                    const s = String(cell || '').trim();
                    if (!s) continue;
                    if (PADROES_COL.data.test(s)) score++;
                    if (PADROES_COL.valor.test(s)) score++;
                    if (PADROES_COL.descricao.test(s)) score++;
                }
                // precisa pelo menos data+valor (score >= 2) OU descricao+valor
                if (score >= 2 && score > melhorScore) {
                    const m = detectarColunas(row);
                    if (m.data >= 0 && m.valor >= 0) {
                        melhor = { linha: i, mapa: m };
                        melhorScore = score;
                    }
                }
            }
            return melhor;
        }

        function normalizarData(v) {
            if (!v) return null;
            if (v instanceof Date && !isNaN(v.getTime())) {
                return v.getFullYear() + '-' + String(v.getMonth()+1).padStart(2,'0') + '-' + String(v.getDate()).padStart(2,'0');
            }
            const str = String(v).trim();
            // yyyy-mm-dd ou yyyy/mm/dd (ISO)
            let m = str.match(/^(\d{4})[\/\-\.](\d{1,2})[\/\-\.](\d{1,2})/);
            if (m) return m[1] + '-' + m[2].padStart(2,'0') + '-' + m[3].padStart(2,'0');
            // dd/mm/yyyy
            m = str.match(/^(\d{1,2})[\/\-\.](\d{1,2})[\/\-\.](\d{2,4})$/);
            if (m) {
                let y = m[3]; if (y.length === 2) y = (parseInt(y,10) >= 50 ? '19' : '20') + y;
                return y + '-' + m[2].padStart(2,'0') + '-' + m[1].padStart(2,'0');
            }
            return null;
        }

        function normalizarValor(v) {
            if (v == null) return 0;
            if (typeof v === 'number') return v;
            let str = String(v).trim().replace(/[^\d,.\-]/g, '');
            if (!str) return 0;
            if (str.indexOf(',') > -1 && str.indexOf('.') > -1) {
                str = str.replace(/\./g, '').replace(',', '.');
            } else if (str.indexOf(',') > -1) {
                str = str.replace(',', '.');
            }
            const n = parseFloat(str);
            return isNaN(n) ? 0 : n;
        }

        function extrairLancamentosDeMatriz(rows, opts) {
            opts = opts || {};
            const forcarNegativo = opts.forcarNegativo === true;
            if (!rows || !rows.length) return [];
            const head = acharLinhaCabecalho(rows);
            if (!head) {
                throw new Error('Cabecalho nao identificado. O arquivo precisa ter colunas de Data e Valor reconheciveis.');
            }
            const { linha, mapa } = head;
            const result = [];
            for (let i = linha + 1; i < rows.length; i++) {
                const r = rows[i];
                if (!r || r.every(c => c === '' || c == null)) continue;
                const data = normalizarData(r[mapa.data]);
                if (!data) continue;  // Sem data = provavelmente linha de TOTAL / subtotal
                let valor = normalizarValor(r[mapa.valor]);
                if (valor === 0) continue;
                if (forcarNegativo) valor = -Math.abs(valor);
                let descA = mapa.descricao >= 0 ? String(r[mapa.descricao] || '').trim() : '';
                let descB = mapa.descricao_aux >= 0 ? String(r[mapa.descricao_aux] || '').trim() : '';
                let descricao = descB ? (descA + ' - ' + descB).replace(/^\s*-\s*|\s*-\s*$/g,'').trim() : descA;
                if (!descricao) descricao = '(sem descricao)';
                let categoria = 'Nao categorizado';
                if (mapa.categoria >= 0) {
                    const cat = String(r[mapa.categoria] || '').trim();
                    if (cat) categoria = cat.charAt(0).toUpperCase() + cat.slice(1).toLowerCase();
                }
                result.push({
                    id: crypto.randomUUID(),
                    data: data,
                    descricao: descricao,
                    valor: valor,
                    empresa: '',
                    cnpj: '',
                    categoria: categoria,
                    contaDebito: '',
                    contaCredito: '',
                    historico: '',
                    incomum: false,
                    origem: 'importacao'
                });
            }
            return result;
        }

                async function parsearArquivoTexto(file, hint, opts) {
            const texto = await lerArquivoTexto(file);
            const linhas = texto.split(/\r?\n/).filter(l => l.trim().length > 0);
            if (linhas.length < 2) throw new Error('Arquivo vazio');
            const candidatos = [';', ',', '\t', '|'];
            let melhorSep = ','; let melhorScore = 0;
            candidatos.forEach(sep => {
                const cont = linhas.slice(0, Math.min(10, linhas.length)).map(l => l.split(sep).length);
                const avg = cont.reduce((a,b) => a+b, 0) / cont.length;
                const consistente = cont.every(n => Math.abs(n - avg) <= 1);
                if (consistente && avg > melhorScore) { melhorScore = avg; melhorSep = sep; }
            });
            if (melhorScore < 3) {
                try {
                    const alt = parsearTextoO2(texto);
                    if (alt.length > 0) return alt;
                } catch (e) {}
                throw new Error('Formato nao reconhecido (use CSV com ;, , tab ou |)');
            }
            const rows = linhas.map(l => l.split(melhorSep).map(c => c.trim().replace(/^["']|["']$/g, '')));
            return extrairLancamentosDeMatriz(rows, opts);
        }

        function lerArquivoTexto(file) {
            return new Promise((resolve, reject) => {
                const r = new FileReader();
                r.onload = e => resolve(e.target.result);
                r.onerror = () => reject(new Error('Falha ao ler arquivo'));
                r.readAsText(file, 'UTF-8');
            });
        }

        async function parsearArquivoO2(file) {
            const texto = await lerArquivoTexto(file);
            return parsearTextoO2(texto);
        }

        function parsearTextoO2(texto) {
            const linhas = texto.split(/\r?\n/);
            const result = [];
            linhas.forEach(linha => {
                if (!linha || !linha.trim()) return;
                const mData = linha.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                if (!mData) return;
                const data = mData[3] + '-' + mData[2] + '-' + mData[1];
                const antesData = linha.substring(0, mData.index);
                const mValor = antesData.match(/(\d{13})\s*$/);
                if (!mValor) return;
                const valor = parseInt(mValor[1], 10) / 100;
                const aposData = linha.substring(mData.index + 10).trim();
                let descricao = aposData.split(/\s{2,}|\t/)[0].trim().replace(/\s*IMP_\w+\s*$/g, '').trim();
                if (!descricao || valor === 0) return;
                result.push({
                    id: crypto.randomUUID(),
                    data: data,
                    descricao: descricao,
                    valor: valor,
                    empresa: '',
                    cnpj: '',
                    categoria: 'Nao categorizado',
                    contaDebito: '',
                    contaCredito: '',
                    historico: '',
                    incomum: false,
                    origem: 'importacao-o2'
                });
            });
            return result;
        }

