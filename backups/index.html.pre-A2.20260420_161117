                    <label>E-mail corporativo</label>
                    <input type="email" id="email" placeholder="seu@spassessoriacontabil.com.br">
                </div>
                <div class="form-group">
                    <label>Senha</label>
                    <input type="password" id="password" placeholder="Digite sua senha">
                </div>
                <button class="btn btn-primary" onclick="doLogin()">Entrar</button>
                <button class="btn btn-secondary" onclick="showRegister()">Criar nova conta</button>
                <div class="error-msg" id="errorMsg"></div>
            </div>
            <div id="registerForm" style="display:none">
                <div class="form-group">
                    <label>E-mail</label>
                    <input type="email" id="regEmail" placeholder="seu@spassessoriacontabil.com.br">
                </div>
                <div class="form-group">
                    <label>Senha</label>
                    <input type="password" id="regPassword" placeholder="Mínimo 6 caracteres">
                </div>
                <div class="form-group">
                    <label>Confirmar Senha</label>
                    <input type="password" id="regPassword2">
                </div>
                <button class="btn btn-primary" onclick="doRegister()">Cadastrar</button>
                <button class="btn btn-secondary" onclick="showLogin()">Voltar ao Login</button>
                <div class="error-msg" id="regErrorMsg"></div>
            </div>
        </div>
    </div>
    
    <!-- App -->
    <div class="app-container" id="appContainer">
        <!-- Header -->
        <div class="header">
            <div class="header-left">
                <div class="header-logo">📊</div>
                <div class="header-title">
                    <h1>CONSULTOR CONTÁBIL INTELIGENTE</h1>
                    <span class="version">v4.0 • Colaborativo</span>
                </div>
            </div>
            <div class="header-right">
                <span id="userEmail"></span>
                <button class="btn-edit-info" onclick="editarInfo()" id="btnEditInfo" style="display:none">
                    ✏️ Editar Empresa
                </button>
                    <button onclick="novaEmpresa()" style="background:#f59e0b;color:#fff;border:none;padding:6px 14px;border-radius:6px;cursor:pointer;font-size:13px;margin-left:8px">🏢 Nova Empresa</button>
                <button class="btn-logout" onclick="doLogout()">Sair</button>
            </div>
        </div>
        
        <!-- Company Info Bar -->
        <div class="company-bar" id="companyBar">
            <div class="company-info">
                <div class="company-main">
                    <h2 id="barEmpresa">-</h2>
                    <p>CNPJ: <span id="barCNPJ">-</span> | Banco: <span id="barBanco">-</span> | Usuário: <span id="barUsuario">-</span> | Período: <span id="barPeriodo">-</span></p>
                </div>
            </div>
        </div>
        
        <!-- Navigation -->
        <div class="nav">
            <button class="active" onclick="showPage('inicio')"><span>🏠</span> Início</button>
            <button onclick="showPage('empresas')"><span>🏢</span> Empresas</button>
            <button onclick="showPage('extrator')"><span>📤</span> Extrator</button>
            <button onclick="showPage('lancamentos')"><span>📋</span> Lançamentos</button>
            <button onclick="showPage('plano')"><span>📚</span> Plano de Contas</button>
            <button onclick="showPage('mapeamento')"><span>🔗</span> Mapeamento</button>
            <button onclick="showPage('exportar')"><span>💾</span> Exportar</button>
            <button onclick="showPage('sobre')"><span>ℹ️</span> Sobre</button>
            <button id="btnAdminNav" onclick="window.open('/admin', '_blank')" style="display:none;margin-left:auto;color:#059669;font-weight:700"><span>👑</span> Admin</button>
        </div>
        
        <!-- Content -->
        <div class="content">
            <!-- Page: Empresas -->
            <div id="pageEmpresas" class="hidden">
                <div class="card" style="padding:24px">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:12px">
                        <h2 style="margin:0;font-size:22px;color:#111827">🏢 Minhas Empresas</h2>
                        <div id="empAdminToggle" style="display:none">
