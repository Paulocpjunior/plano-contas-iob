                    }
                }
            } catch(e) { console.warn('[CAMADA 3] consulta sistema:', e); }
            // Oferecer retomar sessao anterior
            try {
                if (window.API && window.API.carregarSessaoEmpresa) {
                    const sess = await window.API.carregarSessaoEmpresa(cnpj);
                    if (sess && sess.encontrada && sess.state_json) {
