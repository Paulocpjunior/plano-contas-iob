<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Consultor Contábil Inteligente v2.2 - SP Assessoria</title>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <!-- SheetJS para parse de .xlsx/.xls -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="/api-adapter.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #0f172a;
            --primary-light: #1e293b;
            --accent: #3b82f6;
            --accent-light: #60a5fa;
            --accent-glow: rgba(59, 130, 246, 0.25);
            --success: #10b981;
            --success-light: #34d399;
            --warning: #f59e0b;
            --warning-light: #fbbf24;
            --danger: #ef4444;
            --danger-light: #f87171;
            --bg: #f8fafc;
            --bg-dark: #f1f5f9;
            --card: #ffffff;
            --text: #0f172a;
            --text-muted: #64748b;
            --text-light: #94a3b8;
            --border: #e2e8f0;
            --border-light: #f1f5f9;
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1);
            --radius: 16px;
            --radius-sm: 10px;
            --radius-lg: 24px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
            background: var(--bg);
            min-height: 100vh;
            color: var(--text);
            line-height: 1.6;
        }
        
        /* Login */
        .login-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, var(--primary) 0%, #1e3a5f 50%, var(--accent) 100%);
            padding: 20px;
        }
        .login-box {
            background: #fff;
            padding: 48px 40px;
            border-radius: var(--radius-lg);
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.4);
            width: 100%;
            max-width: 440px;
        }
        .login-logo {
            display: flex;
            justify-content: center;
            margin-bottom: 24px;
        }
        .logo-circle {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--accent), var(--primary));
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            color: #fff;
            box-shadow: var(--shadow-lg);
        }
        .login-box h1 {
            color: var(--primary);
            margin-bottom: 6px;
            font-size: 22px;
            text-align: center;
            font-weight: 800;
        }
        .login-box .brand {
            color: var(--accent);
            margin-bottom: 32px;
            text-align: center;
            font-size: 12px;
            letter-spacing: 3px;
            font-weight: 600;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 13px;
            color: var(--text-muted);
        }
        .form-group input {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 15px;
            font-family: inherit;
            transition: all 0.2s;
        }
        .form-group input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 4px var(--accent-glow);
        }
        .btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.2s;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--accent), var(--primary));
            color: #fff;
            margin-bottom: 12px;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }
        .btn-secondary {
            background: var(--bg);
            color: var(--text-muted);
        }
        .error-msg {
            color: var(--danger);
            font-size: 13px;
            margin-top: 16px;
            text-align: center;
            padding: 12px;
            background: #fef2f2;
            border-radius: var(--radius-sm);
            display: none;
        }
        
        /* App Container */
        .app-container { display: none; }
        
        /* Header */
        .header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: #fff;
            padding: 16px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .header-logo {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.15);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }
        .header-title h1 {
            font-size: 18px;
            font-weight: 800;
        }
        .header-title .version {
            font-size: 11px;
            opacity: 0.7;
            font-weight: 500;
        }
        .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .header-right span {
            font-size: 13px;
            opacity: 0.9;
        }
        .btn-logout {
            background: rgba(255,255,255,0.12);
            color: #fff;
            padding: 10px 20px;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            font-family: inherit;
            transition: all 0.2s;
        }
        .btn-logout:hover {
            background: rgba(255,255,255,0.2);
        }
        .btn-edit-info {
            background: rgba(255,255,255,0.1);
            color: #fff;
            padding: 8px 16px;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 12px;
            font-family: inherit;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        /* Company Info Bar */
        .company-bar {
            background: #fff;
            padding: 16px 32px;
            border-bottom: 1px solid var(--border);
            display: none;
        }
        .company-bar.show { display: block; }
        .company-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
        }
        .company-main h2 {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary);
        }
        .company-main p {
            font-size: 13px;
            color: var(--text-muted);
        }
        .company-details {
            display: flex;
            gap: 32px;
            flex-wrap: wrap;
        }
        .company-detail {
            text-align: right;
        }
        .company-detail label {
            font-size: 10px;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            display: block;
        }
        .company-detail span {
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
        }
        
        /* Navigation */
        .nav {
            background: #fff;
            padding: 0 32px;
            display: flex;
            gap: 4px;
            border-bottom: 1px solid var(--border);
            overflow-x: auto;
        }
        .nav button {
            background: none;
            color: var(--text-muted);
            border: none;
            padding: 16px 20px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            border-bottom: 3px solid transparent;
            display: flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
            font-family: inherit;
            transition: all 0.2s;
        }
        .nav button:hover {
            color: var(--accent);
        }
        .nav button.active {
            color: var(--accent);
            border-bottom-color: var(--accent);
        }
        
        /* Content */
        .content {
            padding: 28px 32px;
            max-width: 1600px;
            margin: 0 auto;
        }
        
        /* Cards */
        .card {
            background: #fff;
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
            margin-bottom: 24px;
            border: 1px solid var(--border-light);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .card-header h2 {
            font-size: 16px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .card-header h2 .icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--accent-glow), rgba(59,130,246,0.1));
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }
        
        /* Dashboard Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }
        .stat-card {
            background: #fff;
            padding: 24px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
            position: relative;
            overflow: hidden;
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--accent);
        }
        .stat-card.success::before { background: var(--success); }
        .stat-card.warning::before { background: var(--warning); }
        .stat-card.danger::before { background: var(--danger); }
        .stat-card h3 {
            color: var(--text-muted);
            font-size: 11px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }
        .stat-card .value {
            font-size: 32px;
            font-weight: 800;
            color: var(--text);
        }
        .stat-card .sub {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
        }
        .stat-card.highlight {
            background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 100%);
            border: none;
        }
        .stat-card.highlight::before { display: none; }
        .stat-card.highlight h3,
        .stat-card.highlight .value,
        .stat-card.highlight .sub { color: #fff; }
        
        /* Charts Grid */
        .charts-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 24px;
        }
        @media (max-width: 1024px) {
            .charts-grid { grid-template-columns: 1fr; }
        }
        .chart-container {
            background: #fff;
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-light);
        }
        .chart-container h3 {
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--text);
        }
        .chart-wrapper {
            position: relative;
            height: 280px;
        }
        
        /* Alerts */
        .alert {
            padding: 16px 20px;
            border-radius: var(--radius-sm);
            margin-bottom: 16px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }
        .alert-warning {
            background: #fffbeb;
            border: 1px solid #fde68a;
            color: #92400e;
        }
        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
        }
        .alert-icon {
            font-size: 20px;
            flex-shrink: 0;
        }
        .alert-content h4 {
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .alert-content p {
            font-size: 13px;
            line-height: 1.5;
        }
        
        /* Filters */
        .filters-section {
            background: var(--bg);
            border-radius: var(--radius-sm);
            padding: 20px;
            margin-bottom: 20px;
        }
        .filters-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
            margin-bottom: 16px;
        }
        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .filter-group label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .filter-group input,
        .filter-group select {
            padding: 10px 14px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-family: inherit;
            background: #fff;
        }
        .filter-group input:focus,
        .filter-group select:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }
        .filters-row {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }
        .btn-clear-filters {
            padding: 10px 20px;
            background: var(--bg-dark);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            color: var(--text-muted);
        }
        
        /* Table */
        .table-container {
            overflow-x: auto;
        }
        .table-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border-light);
            flex-wrap: wrap;
            gap: 12px;
        }
        .table-info-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .table-info-left span {
            font-size: 13px;
            color: var(--text-muted);
        }
        .file-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            background: var(--bg);
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            color: var(--accent);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        th, td {
            padding: 14px 12px;
            text-align: left;
            border-bottom: 1px solid var(--border-light);
        }
        th {
            background: var(--bg);
            font-weight: 700;
            color: var(--text-muted);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            position: sticky;
            top: 0;
        }
        tr:hover {
            background: var(--bg);
        }
        tr.unusual {
            background: #fffbeb;
        }
        tr.unusual:hover {
            background: #fef3c7;
        }
        tr.pendente {
            background: #f0f9ff;
        }
        tr.pendente:hover {
            background: #e0f2fe;
        }
        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }
        .badge-green { background: #dcfce7; color: #166534; }
        .badge-blue { background: #dbeafe; color: #1e40af; }
        .badge-yellow { background: #fef3c7; color: #92400e; }
        .badge-red { background: #fee2e2; color: #991b1b; }
        .badge-gray { background: #f1f5f9; color: #475569; }
        .badge-purple { background: #f3e8ff; color: #7c3aed; }
        
        .valor-positivo {
            color: var(--success);
            font-weight: 700;
        }
        .valor-negativo {
            color: var(--danger);
            font-weight: 700;
        }
        .saldo-positivo {
            color: var(--success);
            font-weight: 600;
        }
        .saldo-negativo {
            color: var(--danger);
            font-weight: 600;
        }
        
        .btn-sugestao {
            background: none;
            border: none;
            color: var(--accent);
            font-size: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 4px;
            font-family: inherit;
        }
        
        .editable-input {
            width: 100%;
            padding: 8px 10px;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 12px;
            font-family: inherit;
        }
        .editable-input:focus {
            border-color: var(--accent);
            outline: none;
        }
        
        /* Action Buttons */
        .action-buttons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        .btn-action {
            padding: 12px 24px;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            display: flex;
            align-items: center;
            gap: 8px;
            border: none;
            transition: all 0.2s;
        }
        .btn-action-primary {
            background: var(--accent);
            color: #fff;
        }
        .btn-action-primary:hover {
            background: #2563eb;
        }
        .btn-action-success {
            background: var(--success);
            color: #fff;
        }
        .btn-action-warning {
            background: var(--warning);
            color: #fff;
        }
        .btn-action-warning:disabled {
            background: var(--text-light);
            cursor: wait;
        }
        .btn-action-secondary {
            background: var(--bg);
            color: var(--text);
            border: 1px solid var(--border);
        }
        
        /* Export Dropdown */
        .dropdown {
            position: relative;
        }
        .dropdown-menu {
            position: absolute;
            top: 100%;
            right: 0;
            background: #fff;
            border-radius: var(--radius-sm);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border);
            min-width: 200px;
            z-index: 100;
            display: none;
            margin-top: 4px;
        }
        .dropdown-menu.show { display: block; }
        .dropdown-item {
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            font-size: 13px;
            color: var(--text);
            border: none;
            background: none;
            width: 100%;
            text-align: left;
            font-family: inherit;
        }
        .dropdown-item:hover {
            background: var(--bg);
        }
        .dropdown-item:first-child {
            border-radius: var(--radius-sm) var(--radius-sm) 0 0;
        }
        .dropdown-item:last-child {
            border-radius: 0 0 var(--radius-sm) var(--radius-sm);
        }
        
        /* Upload Section */
        .upload-section {
            background: linear-gradient(135deg, #f8fafc, #f1f5f9);
            border-radius: var(--radius-lg);
            padding: 40px;
            border: 1px solid var(--border);
        }
        .upload-section h3 {
            font-size: 20px;
            text-align: center;
            margin-bottom: 8px;
            font-weight: 700;
        }
        .upload-section > p {
            color: var(--text-muted);
            text-align: center;
            margin-bottom: 32px;
            font-size: 14px;
        }
        .upload-zone {
            border: 3px dashed #cbd5e1;
            border-radius: var(--radius);
            padding: 60px 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: linear-gradient(180deg, #fff, #f8fafc);
        }
        .upload-zone:hover {
            border-color: var(--accent);
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(59,130,246,0.15);
        }
        .upload-zone.dragover {
            border-color: var(--success);
            background: linear-gradient(180deg, #ecfdf5, #d1fae5);
        }
        .upload-icon {
            width: 100px;
            height: 100px;
            margin: 0 auto 24px;
            background: linear-gradient(135deg, var(--accent), #1d4ed8);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            color: #fff;
            box-shadow: 0 15px 40px rgba(59,130,246,0.3);
            position: relative;
        }
        .upload-icon::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--accent), #1d4ed8);
            border-radius: 24px;
            opacity: 0.3;
            animation: pulse 2s ease-in-out infinite;
            z-index: -1;
        }
        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.15); opacity: 0.1; }
        }
        .upload-zone h4 {
            font-size: 20px;
            margin-bottom: 8px;
            font-weight: 700;
        }
        .upload-zone .subtitle {
            color: var(--text-muted);
            margin-bottom: 20px;
        }
        .upload-formats {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .format-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 18px;
            background: #fff;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 600;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            border: 1px solid var(--border);
        }
        .format-badge.pdf { color: #ef4444; border-color: #fecaca; }
        .format-badge.ofx { color: #10b981; border-color: #a7f3d0; }
        .format-badge.csv { color: #f59e0b; border-color: #fde68a; }
        .upload-hint {
            margin-top: 24px;
            padding: 16px;
            background: rgba(59,130,246,0.06);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            gap: 12px;
            justify-content: center;
        }
        .upload-hint span {
            font-size: 13px;
            color: var(--accent);
            font-weight: 500;
        }
        
        /* File Preview */
        .file-preview {
            display: none;
            background: #fff;
            border-radius: var(--radius);
            padding: 24px;
            margin-top: 24px;
            border: 2px solid var(--accent);
        }
        .file-preview.show {
            display: block;
            animation: slideUp 0.3s;
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .file-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        .file-icon {
            width: 64px;
            height: 64px;
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
        }
        .file-icon.pdf { background: linear-gradient(135deg, #fef2f2, #fee2e2); color: #ef4444; }
        .file-icon.ofx { background: linear-gradient(135deg, #ecfdf5, #d1fae5); color: #10b981; }
        .file-icon.csv { background: linear-gradient(135deg, #fffbeb, #fef3c7); color: #f59e0b; }
        .file-details { flex: 1; }
        .file-details h4 { font-size: 16px; margin-bottom: 4px; }
        .file-details .meta { font-size: 13px; color: var(--text-muted); }
        .file-actions { display: flex; gap: 12px; }
        .btn-process {
            padding: 14px 32px;
            background: linear-gradient(135deg, var(--success), #059669);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
        }
        .btn-remove {
            padding: 14px 20px;
            background: var(--bg);
            color: var(--text-muted);
            border: none;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-family: inherit;
        }
        
        /* Processing Overlay */
        .processing-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 23, 42, 0.8);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
        }
        .processing-overlay.show { display: flex; }
        .processing-card {
            background: #fff;
            padding: 48px 60px;
            border-radius: var(--radius-lg);
            text-align: center;
            max-width: 500px;
        }
        .processing-icon {
            width: 100px;
            height: 100px;
            margin: 0 auto 28px;
            position: relative;
        }
        .processing-spinner {
            width: 100%;
            height: 100%;
            border: 4px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .processing-icon .inner-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 36px;
            animation: bounce 1s ease-in-out infinite;
        }
        @keyframes bounce {
            0%, 100% { transform: translate(-50%, -50%); }
            50% { transform: translate(-50%, -60%); }
        }
        .processing-card h3 {
            font-size: 22px;
            margin-bottom: 8px;
            font-weight: 700;
        }
        .processing-card p {
            color: var(--text-muted);
            margin-bottom: 28px;
        }
        .progress-bar {
            height: 8px;
            background: var(--border);
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 16px;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--success));
            width: 0%;
            transition: width 0.5s;
        }
        .processing-steps {
            text-align: left;
            background: var(--bg);
            padding: 20px;
            border-radius: var(--radius-sm);
        }
        .step {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            font-size: 14px;
            color: var(--text-muted);
        }
        .step.active { color: var(--accent); font-weight: 600; }
        .step.done { color: var(--success); }
        .step .check {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid currentColor;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }
        .step.done .check {
            background: var(--success);
            border-color: var(--success);
            color: #fff;
        }
        
        /* Success Message */
        .success-message {
            display: none;
            background: linear-gradient(135deg, #ecfdf5, #d1fae5);
            border-radius: var(--radius);
            padding: 32px;
            margin-top: 24px;
            border: 2px solid var(--success);
            text-align: center;
        }
        .success-message.show { display: block; }
        .success-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--success), #059669);
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: #fff;
        }
        .success-message h4 {
            font-size: 20px;
            color: #166534;
            margin-bottom: 8px;
        }
        .success-message p {
            color: #15803d;
            margin-bottom: 20px;
        }
        .success-stats {
            display: flex;
            justify-content: center;
            gap: 32px;
        }
        .success-stat { text-align: center; }
        .success-stat .num {
            font-size: 32px;
            font-weight: 800;
            color: var(--success);
        }
        .success-stat .label {
            font-size: 12px;
            color: #166534;
            text-transform: uppercase;
        }
        
        /* Form Card */
        .form-card {
            background: #fff;
            border-radius: var(--radius-lg);
            padding: 40px;
            box-shadow: var(--shadow-lg);
            max-width: 900px;
            margin: 0 auto;
            border: 1px solid var(--border-light);
        }
        .form-card h2 {
            margin-bottom: 8px;
            font-size: 24px;
            font-weight: 800;
        }
        .form-card > p {
            color: var(--text-muted);
            margin-bottom: 32px;
        }
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }
        .form-grid .half {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .field { margin-bottom: 0; }
        .field label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 13px;
            color: var(--text-muted);
        }
        .field input,
        .field select {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-family: inherit;
        }
        .field input:focus,
        .field select:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }
        .input-group { position: relative; }
        .input-group input { padding-right: 48px; }
        .input-icon {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 18px;
        }
        .input-icon.success { color: var(--success); }
        .input-icon.loading { animation: spin 1s linear infinite; }
        
        /* Plano de Contas */
        .plano-table th,
        .plano-table td {
            padding: 12px 16px;
        }
        
        /* Export Preview */
        .export-preview {
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 11px;
            background: var(--primary);
            color: #e2e8f0;
            padding: 20px;
            border-radius: var(--radius);
            max-height: 300px;
            overflow: auto;
            white-space: pre;
        }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            color: var(--text-muted);
        }
        .empty-state .icon {
            font-size: 80px;
            margin-bottom: 20px;
            opacity: 0.4;
        }
        .empty-state h3 {
            font-size: 18px;
            margin-bottom: 8px;
        }
        
        /* Toast */
        .toast {
            position: fixed;
            bottom: 28px;
            right: 28px;
            padding: 18px 28px;
            border-radius: var(--radius-sm);
            color: #fff;
            font-weight: 600;
            z-index: 2000;
            animation: slideIn 0.3s;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .toast-success { background: linear-gradient(135deg, var(--success), #059669); }
        .toast-error { background: linear-gradient(135deg, var(--danger), #dc2626); }
        @keyframes slideIn {
            from { transform: translateX(120%); }
            to { transform: translateX(0); }
        }
        
        /* Version Info */
        .version-info {
            position: fixed;
            bottom: 16px;
            left: 16px;
            background: rgba(15, 23, 42, 0.9);
            color: #fff;
            padding: 10px 18px;
            border-radius: var(--radius-sm);
            font-size: 12px;
            z-index: 100;
        }
        .version-info strong { color: var(--accent-light); }
        
        /* Hidden */
        .hidden { display: none !important; }
        
        /* Responsive */
        @media (max-width: 768px) {
            .form-grid { grid-template-columns: 1fr; }
            .form-grid .half { grid-template-columns: 1fr; }
            .header { flex-direction: column; gap: 12px; padding: 16px; }
            .content { padding: 16px; }
            .upload-zone { padding: 40px 20px; }
            .charts-grid { grid-template-columns: 1fr; }
            .filters-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
    <!-- Login -->
    <div class="login-container" id="loginContainer">
        <div class="login-box">
            <div class="login-logo">
                <div class="logo-circle">📊</div>
            </div>
