#!/bin/bash
# Predeploy hook — valida index.html antes de commit
# Bloqueia: arquivo corrompido (lines<1000), Firebase ausente, key Gemini vazada
# Whitelist: AIzaSyCQC3uB... = Firebase Web Key publica do projetos-app-sp

set -e
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

if ! git diff --cached --name-only | grep -q "^index.html$"; then
  exit 0  # index.html nao mudou, nada a validar
fi

echo "${YELLOW}[pre-commit] Validando index.html...${NC}"

LINES=$(wc -l < index.html | tr -d ' ')
FIREBASE_REFS=$(grep -c -i "firebase" index.html)
GEMINI_LEAK=$(grep -oE "AIzaSy[A-Za-z0-9_-]{33}" index.html | grep -v "^AIzaSyCQC3uB" | wc -l | tr -d ' ')

FAIL=0
if [ "$LINES" -lt 1000 ]; then
  echo "${RED}🚨 index.html tem apenas $LINES linhas (esperado >1000) — provavelmente corrompido${NC}"
  FAIL=1
fi
if [ "$FIREBASE_REFS" -eq 0 ]; then
  echo "${RED}🚨 index.html nao tem referencias Firebase — provavelmente corrompido${NC}"
  FAIL=1
fi
if [ "$GEMINI_LEAK" -gt 0 ]; then
  echo "${RED}🚨 KEY GEMINI VAZADA no index.html ($GEMINI_LEAK ocorrencia(s))${NC}"
  echo "${RED}   Linhas:${NC}"
  grep -n -oE "AIzaSy[A-Za-z0-9_-]{33}" index.html | grep -v "AIzaSyCQC3uB" | head -5
  FAIL=1
fi

if [ "$FAIL" -eq 1 ]; then
  echo ""
  echo "${RED}Commit BLOQUEADO. Para forcar (NAO RECOMENDADO): git commit --no-verify${NC}"
  exit 1
fi

echo "${GREEN}✅ index.html OK (lines=$LINES, firebase=$FIREBASE_REFS, leak=0)${NC}"
exit 0
